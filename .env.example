# Copy to .env for local dev. On Render these are set in the dashboard / via API.

# PostgreSQL connection string (shares the IAM database).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# MUST match IAM's JWT_SECRET exactly — this service validates IAM-issued tokens.
JWT_SECRET=change-me

# IAM base URL — the /auth/login endpoint proxies credentials here.
IAM_URL=https://iam-nest-wr3k.onrender.com

# SMTP — emails the citizen when staff respond to a request.
# Leave SMTP_HOST empty to disable email (respond still works).
# Gmail: host=smtp.gmail.com port=587 secure=false user=<addr> pass=<App Password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

PORT=3001
