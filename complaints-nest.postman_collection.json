{
  "info": {
    "name": "Complaints Nest API",
    "_postman_id": "complaints-nest-collection",
    "description": "Requests & Complaints system integrated with IAM.\n\nRUN ORDER (top to bottom):\n1. '0 - IAM Setup (run once)' — creates the complaints.* permissions + the complaints.admin role in IAM, then assign it to a user. Needs an IAM ADMIN account.\n2. '1 - Auth' — log in as a complaints.admin user; saves {{token}}.\n3. '2 - Categories' — create a category (saves {{categoryId}}).\n4. '3 - Requests' — public submit (saves {{requestId}}), public lookup, then staff view/assign/respond/delete.\n\nMost IDs are captured automatically by test scripts into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "iamUrl",         "value": "https://iam-nest-wr3k.onrender.com" },
    { "key": "complaintsUrl",  "value": "https://complaints-nest.onrender.com" },
    { "key": "iamToken",       "value": "" },
    { "key": "token",          "value": "" },
    { "key": "permIds",        "value": "[]" },
    { "key": "roleId",         "value": "" },
    { "key": "userId",         "value": "1" },
    { "key": "categoryId",     "value": "1" },
    { "key": "requestId",      "value": "1" },
    { "key": "nationalNumber", "value": "400123456" }
  ],
  "item": [
    {
      "name": "0 - IAM Setup (run once)",
      "description": "Creates the complaints permissions + role in IAM. Run these top-to-bottom ONCE with an IAM admin account. Re-running create-permission/role returns 409 (already exists) — that's fine.",
      "item": [
        {
          "name": "IAM Login (admin) -> saves iamToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) pm.collectionVariables.set('iamToken', res.access_token);",
                  "pm.collectionVariables.set('permIds', '[]');",
                  "console.log('IAM admin token saved; permIds reset');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ADMIN_EMAIL_HERE\",\n  \"password\": \"ADMIN_PASSWORD_HERE\"\n}"
            },
            "description": "Log in as an existing IAM admin (any user allowed to create permissions/roles)."
          }
        },
        {
          "name": "Create permission: complaints.categories.create",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.categories.create\",\n  \"label\": \"Create categories\",\n  \"description\": \"Create a complaints category\"\n}"
            }
          }
        },
        {
          "name": "Create permission: complaints.categories.update",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.categories.update\",\n  \"label\": \"Update categories\",\n  \"description\": \"Update a complaints category\"\n}"
            }
          }
        },
        {
          "name": "Create permission: complaints.categories.delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.categories.delete\",\n  \"label\": \"Delete categories\",\n  \"description\": \"Delete a complaints category\"\n}"
            }
          }
        },
        {
          "name": "Create permission: complaints.requests.view_all",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.requests.view_all\",\n  \"label\": \"View all requests\",\n  \"description\": \"See every request/complaint\"\n}"
            }
          }
        },
        {
          "name": "Create permission: complaints.requests.respond",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.requests.respond\",\n  \"label\": \"Respond to requests\",\n  \"description\": \"Reply + change status (emails the citizen)\"\n}"
            }
          }
        },
        {
          "name": "Create permission: complaints.requests.delete",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) { const ids = JSON.parse(pm.collectionVariables.get('permIds') || '[]'); ids.push(id); pm.collectionVariables.set('permIds', JSON.stringify(ids)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/permissions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.requests.delete\",\n  \"label\": \"Delete requests\",\n  \"description\": \"Delete a request\"\n}"
            }
          }
        },
        {
          "name": "Create role: complaints.admin -> saves roleId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) pm.collectionVariables.set('roleId', id);",
                  "console.log('complaints.admin roleId =', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{iamUrl}}/roles",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"complaints.admin\",\n  \"label\": \"Complaints Admin\",\n  \"description\": \"Staff who manage the complaints system\",\n  \"permissionIds\": {{permIds}}\n}"
            },
            "description": "Uses {{permIds}} captured from the 6 create-permission requests above."
          }
        },
        {
          "name": "Assign complaints.admin to a user",
          "request": {
            "method": "PATCH",
            "url": "{{iamUrl}}/users/{{userId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{iamToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": {{roleId}}\n}"
            },
            "description": "Set {{userId}} (collection variable) to the IAM user who should access complaints. After this, that user's complaints login will succeed."
          }
        }
      ]
    },
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Login (complaints.admin only) -> saves token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) { pm.collectionVariables.set('token', res.access_token); console.log('Token saved'); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{complaintsUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your@email.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "description": "Proxies to IAM. Returns a token ONLY if the user's role is complaints.admin; otherwise 401."
          }
        }
      ]
    },
    {
      "name": "2 - Categories",
      "item": [
        {
          "name": "Get all categories [PUBLIC — no token]",
          "request": {
            "method": "GET",
            "url": "{{complaintsUrl}}/categories",
            "description": "Public — citizens fetch the category list to fill the submit form."
          }
        },
        {
          "name": "Create category [complaints.categories.create] -> saves categoryId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) pm.collectionVariables.set('categoryId', id);",
                  "console.log('categoryId =', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{complaintsUrl}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Infrastructure\",\n  \"arabicName\": \"البنية التحتية\",\n  \"description\": \"Roads, electricity, water\"\n}"
            }
          }
        },
        {
          "name": "Update category [complaints.categories.update]",
          "request": {
            "method": "PATCH",
            "url": "{{complaintsUrl}}/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            }
          }
        },
        {
          "name": "Delete category [complaints.categories.delete]",
          "request": {
            "method": "DELETE",
            "url": "{{complaintsUrl}}/categories/{{categoryId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "3 - Requests",
      "item": [
        {
          "name": "Submit request [PUBLIC — no token] -> saves requestId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const id = pm.response.json().id;",
                  "if (id) pm.collectionVariables.set('requestId', id);",
                  "console.log('requestId =', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{complaintsUrl}}/requests",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"citizen\": {\n    \"firstName\": \"Ahmad\",\n    \"lastName\": \"Khalil\",\n    \"email\": \"PUT_A_REAL_EMAIL_HERE@example.com\",\n    \"phone\": \"0590000000\",\n    \"address\": \"Gaza, Al-Rimal\",\n    \"nationalNumber\": \"{{nationalNumber}}\"\n  },\n  \"categoryId\": {{categoryId}},\n  \"type\": \"complaint\",\n  \"description\": \"The road has a large pothole causing accidents\"\n}"
            },
            "description": "Public — no token. Citizen is upserted by nationalNumber. Use a REAL email if you want to receive the response email later."
          }
        },
        {
          "name": "Get my requests by national number [PUBLIC — no token]",
          "request": {
            "method": "GET",
            "url": "{{complaintsUrl}}/requests/my?nationalNumber={{nationalNumber}}",
            "description": "Public lookup. Returns [] for an unknown national number."
          }
        },
        {
          "name": "Get all requests [complaints.requests.view_all]",
          "request": {
            "method": "GET",
            "url": "{{complaintsUrl}}/requests",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Respond to request [complaints.requests.respond] — EMAILS the citizen",
          "request": {
            "method": "PATCH",
            "url": "{{complaintsUrl}}/requests/{{requestId}}/respond",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"response\": \"We have dispatched a repair team. Expected fix within 48 hours.\",\n  \"status\": \"resolved\"\n}"
            },
            "description": "Saves the response + status AND emails the citizen (the email on the linked citizen record) via SMTP."
          }
        },
        {
          "name": "Delete request [complaints.requests.delete]",
          "request": {
            "method": "DELETE",
            "url": "{{complaintsUrl}}/requests/{{requestId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
